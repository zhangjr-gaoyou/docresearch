DASHSCOPE_API_KEY=your_bailian_api_key_here

# Optional LLM HTTP settings (see app/core/settings.py)
# LLM_TIMEOUT_SECONDS=600
# LLM_MAX_RETRIES=2
# LLM_MAX_OUTPUT_TOKENS=8192
# LLM_MERGE_MODEL=
# ROUTE_TEMPERATURE=0
# FINAL_MERGE_TEMPERATURE=0
# MERGE_STRATEGY=pairwise
# MERGE_MAX_SINGLE_PROMPT_CHARS=45000
# MERGE_PAIR_MAX_CHARS_EACH=22000
# MERGE_SKIP_LLM_OVER_ESTIMATED_TOKENS=10000
# MERGE_ESTIMATED_CHARS_PER_TOKEN=2.0
# STEP_OUTPUT_VALIDATE_RETRIES=1
# STEP_MAIN_PROMPT_MAX_CHARS=12000
# STEP_MAP_MERGE_MAX_PROMPT_CHARS=22000
# STEP_MAP_MERGE_PAIR_MAX_CHARS_EACH=14000
# STEP_MAP_MERGE_MAX_DEPTH=8

# Optional Neo4j graph store settings
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_password
# NEO4J_DATABASE=neo4j
